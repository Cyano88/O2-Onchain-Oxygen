# ─── X Layer Network ────────────────────────────────────────────────────────────
# Mainnet: https://rpc.xlayer.tech  |  Testnet: https://testrpc.xlayer.com
X_LAYER_RPC=https://testrpc.xlayer.com
X_LAYER_WS_RPC=wss://testrpc.xlayer.com
X_LAYER_CHAIN_ID=195

# ─── Agent Identity ──────────────────────────────────────────────────────────────
# The AI agent's self-custodied private key. NEVER commit this.
AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── OKX OnchainOS ───────────────────────────────────────────────────────────────
OKX_API_KEY=YOUR_OKX_API_KEY
OKX_API_SECRET=YOUR_OKX_API_SECRET
OKX_PASSPHRASE=YOUR_OKX_PASSPHRASE

# ─── Metabolic Thresholds ────────────────────────────────────────────────────────
# Minimum OKB balance (in ETH units) before triggering a refuel cycle
MIN_GAS_THRESHOLD=0.05

# Minimum USD value of unclaimed fees to consider harvesting (profitability guard)
MIN_HARVEST_USD=2.00

# How often the metabolic monitor polls (milliseconds)
POLL_INTERVAL_MS=60000

# Minimum incoming OKB to trigger autonomous_bootstrap (WebSocket event)
BOOTSTRAP_THRESHOLD_OKB=0.5

