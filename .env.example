# ─── X Layer Network ─────────────────────────────────────────────────────────────
# Testnet chain ID: 1952 (0x7a0) — verified live 2026-04-15
# Mainnet chain ID: 196  (0xc4)
X_LAYER_RPC=https://testrpc.xlayer.tech
X_LAYER_WS_RPC=wss://testrpc.xlayer.tech
X_LAYER_CHAIN_ID=1952

# ─── Agent Identity ───────────────────────────────────────────────────────────────
# The AI agent's self-custodied EVM wallet. NEVER commit the real key.
# Generate a fresh keypair: node -e "const {ethers}=require('ethers'); const w=ethers.Wallet.createRandom(); console.log(w.address, w.privateKey)"
AGENT_ADDRESS=0xd018029D7C7e4ed9f50D4Cc56f82B484449A8C00
AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── OKX OnchainOS ────────────────────────────────────────────────────────────────
OKX_API_KEY=YOUR_OKX_API_KEY
OKX_API_SECRET=YOUR_OKX_API_SECRET
OKX_PASSPHRASE=YOUR_OKX_PASSPHRASE

# ─── Metabolic Thresholds ─────────────────────────────────────────────────────────
# Minimum OKB balance before triggering auto-refuel cycle
MIN_GAS_THRESHOLD=0.05

# Minimum USD value of unclaimed fees required to harvest (profitability guard)
MIN_HARVEST_USD=2.00

# Metabolism poll interval (milliseconds)
POLL_INTERVAL_MS=60000

# Minimum incoming OKB in a single tx to trigger autonomous_bootstrap (WebSocket)
BOOTSTRAP_THRESHOLD_OKB=0.5

